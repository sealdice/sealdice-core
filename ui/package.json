{
  "name": "ui",
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "browserslist": [
    "Chrome >= 90"
  ],
  "scripts": {
    "dev": "vite --port 5175 --strictPort",
    "build": "pnpm run generate-api && pnpm run build:prepared",
    "build:analyze": "vite build --mode analyze",
    "build:embed": "pnpm run generate-api && pnpm run build:embed:prepared",
    "build:prepared": "pnpm run type-check && pnpm run build-only",
    "build:embed:prepared": "pnpm run type-check && vite build --mode embed",
    "preview": "vite preview",
    "build-only": "vite build",
    "test": "node scripts/run-tests.mjs",
    "type-check": "vue-tsc --build",
    "lint:oxlint": "oxlint . --fix -D correctness --ignore-path .gitignore",
    "lint:eslint": "eslint . --fix",
    "lint": "pnpm run lint:oxlint && pnpm run lint:eslint",
    "format": "prettier --write src/",
    "generate-openapi": "cd .. && go run . --gen-openapi=./ui/openapi.json",
    "generate-client": "openapi-ts",
    "generate-api": "pnpm run generate-openapi && pnpm run generate-client"
  },
  "dependencies": {
    "@ant-design/colors": "^8.0.1",
    "@codemirror/autocomplete": "^6.20.2",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.0",
    "@tanstack/vue-query": "^5.92.1",
    "@tanstack/vue-virtual": "^3.13.25",
    "@ungap/structured-clone": "^1.3.0",
    "@vueuse/core": "^14.3.0",
    "codemirror": "^6.0.2",
    "dayjs": "^1.11.18",
    "docx": "^8.6.0",
    "dompurify": "^3.3.0",
    "eruda": "^3.4.3",
    "es-toolkit": "^1.39.10",
    "fake-qq-ui": "file:vendor/fake-qq-ui",
    "file-saver": "^2.0.5",
    "filesize": "^11.0.13",
    "hyparquet": "^1.15.0",
    "hyparquet-compressors": "^1.1.1",
    "hyperparam": "^0.2.49",
    "mitt": "^3.0.1",
    "naive-ui": "^2.43.1",
    "nprogress": "^0.2.0",
    "pinyin-pro": "^3.28.1",
    "pro-naive-ui": "^3.2.3",
    "pro-naive-ui-resolver": "^1.0.2",
    "randomcolor": "^0.6.2",
    "vue": "^3.5.34",
    "vue-codemirror6": "^1.5.2",
    "vue-diff": "^1.2.4",
    "vue-draggable-next": "^2.3.0",
    "vue-router": "^5.0.7"
  },
  "devDependencies": {
    "@csstools/postcss-color-mix-function": "^3.0.12",
    "@hey-api/openapi-ts": "^0.91.1",
    "@iconify-json/bi": "^1.2.7",
    "@iconify-json/carbon": "^1.2.21",
    "@iconify-json/ep": "^1.2.4",
    "@prettier/plugin-oxc": "^0.0.4",
    "@tsconfig/node22": "^22.0.2",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^22.16.5",
    "@types/nprogress": "^0.2.3",
    "@types/randomcolor": "^0.5.9",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitejs/plugin-vue-jsx": "^5.1.4",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/tsconfig": "^0.7.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.31.0",
    "eslint-plugin-oxlint": "~1.8.0",
    "eslint-plugin-vue": "~10.3.0",
    "jiti": "^2.4.2",
    "npm-run-all2": "^8.0.4",
    "oxlint": "~1.8.0",
    "postcss": "^8.5.6",
    "prettier": "3.6.2",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.8.0",
    "unplugin-auto-import": "^20.2.0",
    "unplugin-icons": "^23.0.1",
    "unplugin-vue-components": "^29.1.0",
    "vfonts": "^0.0.3",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-vue-devtools": "^8.0.0",
    "vue-tsc": "^3.0.4"
  }
}
